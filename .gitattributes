# Auto-detect text files and normalize line endings
* text=auto

# Ensure these files are treated as text
*.ts text
*.tsx text
*.js text
*.json text
*.css text
*.md text
*.yml text
*.yaml text

# Prevent binary files from being diffed
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
